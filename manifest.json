{
  "manifest_version": 3,
  "name": "StreamGuard",
  "version": "4.5.4",
  "description": "Multi-site streaming guard with remote domain database, favorites, dev capture, and site modules.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/dev_capture.js"
      ],
      "run_at": "document_idle"
    }
  ]
}